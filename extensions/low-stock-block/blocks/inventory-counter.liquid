{{ 'counter.css' | asset_url | stylesheet_tag }}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign low_stock_threshold = block.settings.low_stock_threshold | default: 10
  assign initial_inventory = current_variant.inventory_quantity | default: 0
  assign initial_percentage = initial_inventory | times: 100.0 | divided_by: low_stock_threshold

  if initial_percentage > 100
    assign initial_percentage = 100
  endif

  if initial_percentage < 0
    assign initial_percentage = 0
  endif
%}

<div
  id="InventoryCounter-{{ block.id }}"
  class="inventory-counter inventory-counter--hidden"
  style="
    --inventory-counter-background: {{ block.settings.background_color }};
    --inventory-counter-text: {{ block.settings.text_color }};
    --inventory-counter-warning: {{ block.settings.pulsing_warning_color }};
    --inventory-counter-fill: {{ block.settings.bar_fill_color }};
  "
  data-inventory-counter
  data-product-id="{{ product.id }}"
  data-initial-variant-id="{{ current_variant.id }}"
  data-initial-inventory="{{ current_variant.inventory_quantity }}"
  data-threshold="{{ low_stock_threshold }}"
  data-message="{{ block.settings.scarcity_text | escape }}"
  data-simulation-start="8"
  data-simulation-minimum="3"
  data-simulation-interval="12000"
  hidden
  {{ block.shopify_attributes }}
>
  <div class="inventory-counter__message" role="status" aria-live="polite">
    <span class="inventory-counter__pulse" aria-hidden="true"></span>
    <span data-inventory-message></span>
  </div>

  <div
    class="inventory-counter__track"
    data-inventory-progress
    role="progressbar"
    aria-label="Stock remaining"
    aria-valuemin="0"
    aria-valuemax="{{ low_stock_threshold }}"
    aria-valuenow="{{ initial_inventory }}"
  >
    <span
      class="inventory-counter__fill"
      data-inventory-fill
      style="width: {{ initial_percentage }}%;"
    ></span>
  </div>

  <script type="application/json" data-inventory-variants>
    {{ product.variants | json }}
  </script>
</div>

{{ 'counter.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Inventory low stock counter",
  "target": "section",
  "settings": [
    {
      "type": "number",
      "id": "low_stock_threshold",
      "label": "Low stock threshold",
      "default": 10
    },
    {
      "type": "text",
      "id": "scarcity_text",
      "label": "Scarcity text",
      "default": "Hurry! Only [count] items left in stock! 🔥",
      "info": "Use [count] where the active variant inventory should appear."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fff4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#8e1f1f"
    },
    {
      "type": "color",
      "id": "pulsing_warning_color",
      "label": "Pulsing warning color",
      "default": "#d72c0d"
    },
    {
      "type": "color",
      "id": "bar_fill_color",
      "label": "Progress bar fill color",
      "default": "#d72c0d"
    }
  ]
}
{% endschema %}
