{% liquid
  assign active_variant = product.selected_or_first_available_variant
  assign threshold = block.settings.low_stock_threshold | default: 10
  assign is_product_page = false

  if request.page_type == 'product' and product != blank
    assign is_product_page = true
  endif
%}

{% if is_product_page %}
  <div
    id="LowStockCounter-{{ block.id }}"
    class="zoro-low-stock"
    style="
      --zoro-low-stock-bg: {{ block.settings.background_color }};
      --zoro-low-stock-text: {{ block.settings.text_color }};
      --zoro-low-stock-accent: {{ block.settings.warning_color }};
      --zoro-low-stock-track: {{ block.settings.track_color }};
      --zoro-low-stock-radius: {{ block.settings.corner_radius }}px;
      --zoro-low-stock-size: {{ block.settings.font_size }}px;
      --zoro-low-stock-gap-top: {{ block.settings.spacing_top }}px;
      --zoro-low-stock-gap-bottom: {{ block.settings.spacing_bottom }}px;
    "
    data-zoro-low-stock
    data-threshold="{{ threshold }}"
    data-alert-text="{{ block.settings.alert_text | escape }}"
    data-sold-out-text="{{ block.settings.sold_out_text | escape }}"
    data-show-progress="{{ block.settings.show_progress }}"
    data-show-sold-out="{{ block.settings.show_sold_out }}"
    data-current-variant="{{ active_variant.id }}"
    hidden
    {{ block.shopify_attributes }}
  >
    <div class="zoro-low-stock__message" role="status" aria-live="polite" aria-atomic="true">
      <span class="zoro-low-stock__dot" aria-hidden="true"></span>
      <span data-zoro-low-stock-message></span>
    </div>

    {% if block.settings.show_progress %}
      <div class="zoro-low-stock__track" data-zoro-low-stock-track aria-hidden="true">
        <span class="zoro-low-stock__fill" data-zoro-low-stock-fill></span>
      </div>
    {% endif %}

    <script type="application/json" data-zoro-low-stock-variants>
      [
        {% for variant in product.variants %}
          {
            "id": {{ variant.id | json }},
            "available": {{ variant.available | json }},
            "quantity": {{ variant.inventory_quantity | json }},
            "management": {{ variant.inventory_management | json }},
            "policy": {{ variant.inventory_policy | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    </script>
  </div>

  <style>
    #LowStockCounter-{{ block.id }} {
      display: block;
      width: 100%;
      box-sizing: border-box;
      margin: var(--zoro-low-stock-gap-top) 0 var(--zoro-low-stock-gap-bottom);
      padding: 0.75rem 0.9rem;
      border: 1px solid color-mix(in srgb, var(--zoro-low-stock-accent) 22%, transparent);
      border-radius: var(--zoro-low-stock-radius);
      background: var(--zoro-low-stock-bg);
      color: var(--zoro-low-stock-text);
      font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif);
      font-size: var(--zoro-low-stock-size);
      line-height: 1.3;
      clear: both;
      position: static;
      z-index: auto;
    }

    #LowStockCounter-{{ block.id }}[hidden] {
      display: none !important;
    }

    #LowStockCounter-{{ block.id }} .zoro-low-stock__message {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      font-weight: 700;
    }

    #LowStockCounter-{{ block.id }} .zoro-low-stock__dot {
      width: 0.48rem;
      height: 0.48rem;
      flex: 0 0 auto;
      border-radius: 999px;
      background: var(--zoro-low-stock-accent);
      animation: zoro-low-stock-pulse-{{ block.id }} 1.55s ease-out infinite;
    }

    #LowStockCounter-{{ block.id }} .zoro-low-stock__track {
      height: 0.35rem;
      margin-top: 0.65rem;
      overflow: hidden;
      border-radius: 999px;
      background: var(--zoro-low-stock-track);
    }

    #LowStockCounter-{{ block.id }} .zoro-low-stock__fill {
      display: block;
      width: 0;
      height: 100%;
      border-radius: inherit;
      background: var(--zoro-low-stock-accent);
      transition: width 240ms ease;
    }

    @keyframes zoro-low-stock-pulse-{{ block.id }} {
      0% {
        box-shadow: 0 0 0 0 color-mix(in srgb, var(--zoro-low-stock-accent) 42%, transparent);
        transform: scale(0.92);
      }
      75%,
      100% {
        box-shadow: 0 0 0 0.55rem transparent;
        transform: scale(1);
      }
    }
  </style>

  <script>
    (() => {
      const root = document.getElementById('LowStockCounter-{{ block.id }}');
      if (!root) return;

      const data = root.querySelector('[data-zoro-low-stock-variants]');
      const message = root.querySelector('[data-zoro-low-stock-message]');
      const fill = root.querySelector('[data-zoro-low-stock-fill]');
      const threshold = Math.max(0, Number(root.dataset.threshold || 10));
      const alertText = root.dataset.alertText || 'Hurry! Only [count] items left in stock!';
      const soldOutText = root.dataset.soldOutText || 'This item is currently sold out.';
      const showSoldOut = root.dataset.showSoldOut === 'true';

      let variants = [];
      try {
        variants = JSON.parse(data?.textContent || '[]');
      } catch (error) {
        variants = [];
      }

      const byId = new Map(variants.map((variant) => [String(variant.id), variant]));

      const selectedVariantId = () => {
        const params = new URLSearchParams(window.location.search);
        const fromUrl = params.get('variant');
        if (fromUrl && byId.has(fromUrl)) return fromUrl;

        const input = document.querySelector('form[action*="/cart/add"] [name="id"]');
        if (input?.value && byId.has(String(input.value))) return String(input.value);

        return root.dataset.currentVariant || String(variants[0]?.id || '');
      };

      const setProgress = (quantity) => {
        if (!fill) return;
        const percent = threshold > 0 ? Math.max(0, Math.min(100, (quantity / threshold) * 100)) : 0;
        fill.style.width = `${percent}%`;
      };

      const render = () => {
        const variant = byId.get(selectedVariantId());
        if (!variant) {
          root.hidden = true;
          return;
        }

        const tracked = Boolean(variant.management) && variant.policy !== 'continue';
        const quantity = Number(variant.quantity);

        if (!variant.available || (tracked && quantity <= 0)) {
          if (!showSoldOut) {
            root.hidden = true;
            return;
          }
          message.textContent = soldOutText;
          setProgress(0);
          root.hidden = false;
          return;
        }

        if (!tracked || !Number.isFinite(quantity) || quantity > threshold) {
          root.hidden = true;
          return;
        }

        message.textContent = alertText.replace(/\[count\]/g, String(quantity));
        setProgress(quantity);
        root.hidden = false;
      };

      document.addEventListener('change', render);
      document.addEventListener('input', render);
      document.addEventListener('variant:change', render);
      document.addEventListener('shopify:section:load', render);
      window.addEventListener('popstate', render);
      render();
      setTimeout(render, 120);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Low stock counter",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Inventory"
    },
    {
      "type": "number",
      "id": "low_stock_threshold",
      "label": "Low-stock threshold",
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "show_sold_out",
      "label": "Show sold-out message",
      "default": true
    },
    {
      "type": "text",
      "id": "alert_text",
      "label": "Low-stock text",
      "default": "Hurry! Only [count] items left in stock!"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold-out text",
      "default": "This item is currently sold out."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFF4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#8E1F1F"
    },
    {
      "type": "color",
      "id": "warning_color",
      "label": "Warning color",
      "default": "#D72C0D"
    },
    {
      "type": "color",
      "id": "track_color",
      "label": "Progress track color",
      "default": "#F2C6C1"
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Space above",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Space below",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16,
      "unit": "px"
    }
  ]
}
{% endschema %}
