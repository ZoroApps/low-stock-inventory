  @keyframes zoro-adaptive-pulse-{{ block.id }} {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, {{ block.settings.warning_color }} 44%, transparent); transform: scale(.9); }
    80%, 100% { box-shadow: 0 0 0 .5rem transparent; transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .zoro-adaptive-stock-badge-{{ block.id }}::before { animation: none; }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('LowStockCounter-{{ block.id }}');
    if (!root || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const message = root.querySelector('[data-zoro-message]');
    const progress = root.querySelector('[data-zoro-progress]');
    const fill = root.querySelector('[data-zoro-fill]');
    const source = root.querySelector('[data-zoro-variants]');
    const inventory = root.querySelector('[data-zoro-inventory]');
    const soldOutBadge = root.querySelector('[data-zoro-sold-out-badge]');
    const pair = root.querySelector('[data-zoro-pair]');
    const companionVariant = root.querySelector('[data-zoro-companion-variant]');
    const addBothButton = root.querySelector('[data-zoro-add-both]');
    const pairStatus = root.querySelector('[data-zoro-pair-status]');
    const threshold = Math.max(1, Number(root.dataset.threshold) || 10);
    const displayMode = root.dataset.displayMode || 'always';
    const designMode = root.dataset.designMode === 'true';
    const showProgress = root.dataset.showProgress === 'true';
    const variants = JSON.parse(source?.textContent || '[]');
    const pageType = root.dataset.pageType;
    let updateTimer;
    let portal;
    let lastPortalRender;
    let portalWatch;

    const text = (template, count) =>
      (template || '').split('[count]').join(String(count));

    const setRootVisibility = () => {
      root.hidden = inventory.hidden && !pair;
    };

    const visibleBox = (node) => {
      const box = node?.getBoundingClientRect?.();
      if (!box || box.width < 1 || box.height < 1) return null;
      const style = window.getComputedStyle(node);
      if (style.display === 'none' || style.visibility === 'hidden' || Number(style.opacity) === 0) {
        return null;
      }
      return box;
    };

    const purchaseCopy = (node) =>
      (node?.textContent || node?.value || node?.getAttribute?.('aria-label') || '')
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();

    const purchaseButtons = () => [...document.querySelectorAll([
        'button',
        'input[type="submit"]',
        'a',
        '[role="button"]',
        '[name="add"]',
        '[class*="button"]',
        '[class*="payment-button"]'
      ].join(', '))]
        .filter((button) => {
          const copy = purchaseCopy(button);
          return !root.contains(button) && visibleBox(button) && /add to cart|buy it now|sold out/.test(copy);
        })
        .sort((left, right) => {
          const leftCopy = purchaseCopy(left);
          const rightCopy = purchaseCopy(right);
          const leftPriority = /add to cart|sold out/.test(leftCopy) ? 0 : 1;
          const rightPriority = /add to cart|sold out/.test(rightCopy) ? 0 : 1;
          const leftBox = left.getBoundingClientRect();
          const rightBox = right.getBoundingClientRect();
          return (leftPriority - rightPriority) || (rightBox.left - leftBox.left) || (leftBox.top - rightBox.top);
        });

    const purchaseColumnBox = () => {
      const button = purchaseButtons()[0];
      const buttonBox = visibleBox(button);
      if (!buttonBox) return null;

      const shell = purchaseShell(button);
      const shellBox = visibleBox(shell);
      if (shellBox && shellBox.width <= window.innerWidth * 0.62) return shellBox;

      return buttonBox;
    };

    const productForm = () => {
      const columnBox = purchaseColumnBox();
      const forms = [...document.querySelectorAll('form[action*="/cart/add"]')]
        .filter((form) => {
          const box = visibleBox(form);
          if (!box || root.contains(form)) return false;
          if (!columnBox) return true;
          const overlap = Math.min(box.right, columnBox.right) - Math.max(box.left, columnBox.left);
          return box.width <= window.innerWidth * 0.62 && overlap > columnBox.width * 0.5;
        })
        .map((form) => {
          const box = form.getBoundingClientRect();
          const copy = purchaseCopy(form);
          return {
            form,
            priority: /add to cart|buy it now|sold out/.test(copy) ? 0 : 1,
            left: box.left,
            top: box.top
          };
        })
        .sort((left, right) =>
          (left.priority - right.priority)
          || (right.left - left.left)
          || (left.top - right.top)
        );

      return forms[0]?.form || null;
    };

    const purchaseShell = (node) =>
      node.closest?.([
        'form[action*="/cart/add"]',
        'product-form',
        '.product-form',
        '[class*="product-form"]',
        '[class*="buy-buttons"]',
        '[class*="payment-button"]',
        '[class*="quantity"]'
      ].join(', ')) || node;

    const purchaseTarget = () => {
      const form = productForm();
      if (visibleBox(form)) return { node: form, mode: 'before' };

      const purchaseButton = purchaseButtons()[0];
      if (!purchaseButton) return null;

      const shell = purchaseShell(purchaseButton);
      const shellBox = visibleBox(shell);
      if (shellBox && shellBox.width <= window.innerWidth * 0.62) {
        return {
          node: shell,
          mode: 'before'
        };
      }

      return {
        node: purchaseButton,
        mode: 'before'
      };
    };

    const visiblePriceTarget = () => {
      const purchaseBox = purchaseColumnBox() || visibleBox(purchaseTarget()?.node);
      if (!purchaseBox) return null;

      const candidates = [...document.querySelectorAll([
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]',
        'span',
        'div',
        'p',
        'dd'
      ].join(', '))]
        .filter((node) => {
          if (node === root || root.contains(node) || node.contains(root)) return false;
          const copy = (node.textContent || '').replace(/\s+/g, ' ').trim();
          if (!/[$£€]|(?:^|\s)(?:USD|CAD|AUD|GBP|EUR)(?:\s|$)|\d+[.,]\d{2}/.test(copy)) return false;
          if (copy.length > 80) return false;
          const box = visibleBox(node);
          if (!box || box.bottom > purchaseBox.top + 24) return false;
          const overlap = Math.min(box.right, purchaseBox.right) - Math.max(box.left, purchaseBox.left);
          const center = (box.left + box.right) / 2;
          return overlap > Math.min(box.width, purchaseBox.width) * 0.25
            || (center >= purchaseBox.left && center <= purchaseBox.right);
        })
        .sort((left, right) => {
          const leftBox = left.getBoundingClientRect();
          const rightBox = right.getBoundingClientRect();
          return Math.abs(purchaseBox.top - leftBox.bottom) - Math.abs(purchaseBox.top - rightBox.bottom);
        });

      return candidates[0] ? { node: candidates[0], mode: 'after' } : null;
    };

    const exactCurrentPriceTarget = () => {
      const money = (root.dataset.currentMoney || '').replace(/\s+/g, ' ').trim();
      const price = (root.dataset.currentPrice || '').replace(/\s+/g, ' ').trim();
      const needles = [money, price].filter(Boolean);
      if (!needles.length) return null;
      const purchaseBox = purchaseColumnBox() || visibleBox(purchaseTarget()?.node);
      const nearPurchase = (node) => {
        if (!purchaseBox) return true;
        const box = visibleBox(node);
        if (!box || box.bottom > purchaseBox.top + 48) return false;
        const overlap = Math.min(box.right, purchaseBox.right) - Math.max(box.left, purchaseBox.left);
        const center = (box.left + box.right) / 2;
        return overlap > Math.min(box.width, purchaseBox.width) * 0.25
          || (center >= purchaseBox.left && center <= purchaseBox.right);
      };
      const priceScore = (node) => {
        const box = node.getBoundingClientRect();
        const copy = (node.textContent || '').replace(/\s+/g, ' ').trim();
        const exact = needles.some((needle) => copy === needle);
        return {
          exact: exact ? 0 : 1,
          length: copy.length,
          area: box.width * box.height,
          left: box.left,
          top: box.top
        };
      };

      const candidates = [...document.querySelectorAll([
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]',
        'span',
        'div',
        'p',
        'dd'
      ].join(', '))]
        .filter((node) => {
          if (node === root || root.contains(node) || node.contains(root)) return false;
          if (node.closest('button, label, option, select')) return false;
          const box = visibleBox(node);
          if (!box) return false;
          const copy = (node.textContent || '').replace(/\s+/g, ' ').trim();
          if (copy.length > 80) return false;
          return nearPurchase(node) && needles.some((needle) => copy === needle || copy.includes(needle));
        })
        .sort((left, right) => {
          const a = priceScore(left);
          const b = priceScore(right);
          return (a.exact - b.exact)
            || (a.length - b.length)
            || (a.area - b.area)
            || (b.left - a.left)
            || (a.top - b.top);
        });

      return candidates[0] ? { node: candidates[0], mode: 'after' } : null;
    };

    const priceBlockTarget = (target) => {
      const node = target?.node;
      if (!node) return null;
      const anchor = node.closest?.([
        '.price',
        '[data-product-price]',
        '[id*="price" i]',
        '[class*="price" i]'
      ].join(', ')) || node.parentElement || node;
      return { node: anchor, mode: target.mode || 'after' };
    };

    const productInfoContainer = () => {
      const form = productForm();
      const purchase = purchaseTarget()?.node;
      return form?.closest([
        'product-info',
        '.product__info-container',
        '.product__info-wrapper',
        '[class*="product__info"]',
        '[class*="product-info"]'
      ].join(', '))
        || purchase?.closest([
          'product-info',
          '.product__info-container',
          '.product__info-wrapper',
          '[class*="product__info"]',
          '[class*="product-info"]'
        ].join(', '))
        || form?.parentElement
        || purchase?.parentElement
        || null;
    };

    const productPriceTarget = () => {
      const container = productInfoContainer();
      const selectors = [
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]',
        'span',
        'div',
        'p',
        'dd'
      ];
      const blockSelectors = [
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]'
      ];

      if (container) {
        const scopedCandidates = [...container.querySelectorAll(selectors.join(', '))]
          .filter((node) => {
            if (node === root || root.contains(node) || node.contains(root)) return false;
            if (node.closest('[data-zoro-stock], [data-zoro-adaptive-stock]')) return false;
            if (node.closest('button, label, option, select')) return false;
            const copy = (node.textContent || '').replace(/\s+/g, ' ').trim();
            if (!/[$£€]|(?:^|\s)(?:USD|CAD|AUD|GBP|EUR)(?:\s|$)|\d+[.,]\d{2}/.test(copy)) return false;
            if (copy.length > 80) return false;
            return visibleBox(node);
          })
          .sort((left, right) => {
            const purchaseBox = visibleBox(purchaseTarget()?.node);
            const leftBox = left.getBoundingClientRect();
            const rightBox = right.getBoundingClientRect();
            if (purchaseBox) {
              return Math.abs(purchaseBox.top - leftBox.bottom) - Math.abs(purchaseBox.top - rightBox.bottom);
            }
            return (rightBox.left - leftBox.left) || (leftBox.top - rightBox.top);
          });

        const scopedPriceBlock = priceBlockTarget(scopedCandidates[0] ? { node: scopedCandidates[0], mode: 'after' } : null);
        if (scopedPriceBlock) return scopedPriceBlock;

        const form = productForm();
        if (form && container.contains(form)) return { node: form, mode: 'before' };
      }

      const price = exactCurrentPriceTarget() || visiblePriceTarget();
      const priceBlock = priceBlockTarget(price);
      if (priceBlock) return priceBlock;

      for (const selector of blockSelectors) {
        const node = container?.querySelector(selector);
        if (node && !node.contains(root) && !root.contains(node)) {
          return priceBlockTarget({ node, mode: 'after' });
        }
      }

      return purchaseTarget();
    };

    const placeRootNearProductPrice = () => {
      if (pageType !== 'product') return false;
      const target = productPriceTarget();
      if (!target?.node || target.node.contains(root)) return false;

      if (target.mode === 'before') {
        if (target.node.previousElementSibling !== root) {
          target.node.insertAdjacentElement('beforebegin', root);
        }
      } else if (target.node.nextElementSibling !== root) {
        target.node.insertAdjacentElement('afterend', root);
      }

      root.dataset.productPlacement = 'price';
      return true;
    };

    const portalTarget = () => pageType === 'product'
      ? purchaseTarget() || exactCurrentPriceTarget() || visiblePriceTarget()
      : exactCurrentPriceTarget() || visiblePriceTarget() || purchaseTarget();

    const positionProductPortal = (node) => {
      const target = portalTarget();
      if (!node || !target?.node || target.node.contains(node)) return false;

      const previousHidden = node.hidden;
      node.hidden = false;
      node.classList.add('zoro-stock--floating-purchase');

      const box = target.node.getBoundingClientRect();
      const columnBox = purchaseColumnBox() || box;
      const gap = 16;
      const portalBox = node.getBoundingClientRect();
      const width = Math.max(160, Math.min(columnBox.width, window.innerWidth - 24));
      const left = Math.max(12, Math.min(columnBox.left + window.scrollX, window.scrollX + window.innerWidth - width - 12));
      const top = target.mode === 'before'
        ? Math.max(window.scrollY + 12, box.top + window.scrollY - portalBox.height - gap)
        : box.bottom + window.scrollY + gap;
      node.style.setProperty('--zoro-floating-width', `${width}px`);
      node.style.left = `${left}px`;
      node.style.top = `${top}px`;

      node.hidden = previousHidden;
      return true;
    };

    const ensureProductPortal = () => {
      if (pageType !== 'product') return null;
      const target = portalTarget();
      if (!target?.node) return null;

      if (!portal) {
        portal = document.createElement('div');
        portal.id = 'LowStockCounterPortal-{{ block.id }}';
        portal.className = root.className;
        portal.setAttribute('style', root.getAttribute('style') || '');
        portal.setAttribute('role', 'status');
        portal.setAttribute('aria-live', 'polite');
        portal.setAttribute('aria-atomic', 'true');
        portal.innerHTML = `
          <div data-zoro-portal-inventory>
            <div class="zoro-stock__alert">
              {% if block.settings.show_pulse %}
                <span class="zoro-stock__pulse" aria-hidden="true"></span>
              {% endif %}
              <span data-zoro-portal-message></span>
              {% if block.settings.show_sold_out_badge %}
                <span class="zoro-stock__badge" data-zoro-portal-sold-out-badge hidden>
                  {{ block.settings.sold_out_badge_text }}
                </span>
              {% endif %}
            </div>
            <div class="zoro-stock__track" data-zoro-portal-progress hidden>
              <span class="zoro-stock__fill" data-zoro-portal-fill></span>
            </div>
          </div>
        `;
        document.body.appendChild(portal);
      }

      return portal;
    };

    const forceProductInlineSpacing = (node, followingNode = null) => {
      if (!node) return;
      node.style.setProperty('margin-top', '1.25rem', 'important');
      node.style.setProperty('margin-bottom', '3rem', 'important');
      node.style.setProperty('position', 'relative', 'important');
      node.style.setProperty('z-index', '1', 'important');

      let spacer = document.getElementById('LowStockCounterSpacer-{{ block.id }}');
      if (!spacer) {
        spacer = document.createElement('div');
        spacer.id = 'LowStockCounterSpacer-{{ block.id }}';
        spacer.setAttribute('aria-hidden', 'true');
      }
      if (node.nextElementSibling !== spacer) {
        node.insertAdjacentElement('afterend', spacer);
      }
      spacer.style.setProperty('display', 'block', 'important');
      spacer.style.setProperty('height', '1.5rem', 'important');
      spacer.style.setProperty('min-height', '1.5rem', 'important');
      spacer.style.setProperty('clear', 'both', 'important');
      spacer.style.setProperty('pointer-events', 'none', 'important');

      const next = spacer.nextElementSibling;
      if (next && next !== root && !root.contains(next)) {
        next.style.setProperty('margin-top', '1rem', 'important');
        next.style.setProperty('padding-top', '.25rem', 'important');
      }

      if (followingNode && followingNode !== root && !root.contains(followingNode)) {
        followingNode.style.setProperty('margin-top', '3.75rem', 'important');
        followingNode.style.setProperty('padding-top', '1rem', 'important');
      }

      productPurchaseButtons().forEach((button) => {
        button.style.setProperty('margin-top', '2.5rem', 'important');
      });
    };

    const renderProductPortal = (copy, count = 0, progressVisible = false, soldOut = false) => {
      lastPortalRender = { copy, count, progressVisible, soldOut };
      const node = ensureProductPortal();
      if (!node) return false;

      node.querySelector('[data-zoro-portal-message]').textContent = copy;
      const portalBadge = node.querySelector('[data-zoro-portal-sold-out-badge]');
      const portalProgress = node.querySelector('[data-zoro-portal-progress]');
      const portalFill = node.querySelector('[data-zoro-portal-fill]');
      if (portalBadge) portalBadge.hidden = !soldOut;
      portalProgress.hidden = !showProgress || !progressVisible;
      portalFill.style.width = `${Math.min(100, Math.max(0, count / threshold * 100))}%`;

      const purchaseColumnTarget = purchaseTarget();
      const inlineTarget = purchaseColumnTarget?.node && !root.contains(purchaseColumnTarget.node)
        ? purchaseColumnTarget
        : productPriceTarget();
      let resolvedInlineTarget = inlineTarget;
      const inlineForm = resolvedInlineTarget?.node?.closest?.([
        'form[action*="/cart/add"]',
        'product-form',
        '.product-form',
        '[class*="product-form"]'
      ].join(', '));
      if (inlineForm && inlineForm !== resolvedInlineTarget.node && !root.contains(inlineForm)) {
        resolvedInlineTarget = { node: inlineForm, mode: 'before' };
      }
      if (resolvedInlineTarget?.node && !resolvedInlineTarget.node.contains(node)) {
        node.classList.remove('zoro-stock--floating-purchase');
        node.classList.add('zoro-stock--inline-price');
        node.style.removeProperty('--zoro-floating-width');
        node.style.removeProperty('left');
        node.style.removeProperty('top');
        // Product pages prefer the purchase form so the badge stays in the price column.
        if (resolvedInlineTarget.mode === 'before') {
          if (resolvedInlineTarget.node.previousElementSibling !== node) {
            resolvedInlineTarget.node.insertAdjacentElement('beforebegin', node);
          }
        } else if (resolvedInlineTarget.node.nextElementSibling !== node) {
          resolvedInlineTarget.node.insertAdjacentElement('afterend', node);
        }
        forceProductInlineSpacing(node, resolvedInlineTarget.mode === 'before' ? resolvedInlineTarget.node : null);
        node.hidden = false;
        if (isVisible(node)) {
          root.dataset.productPlacement = 'price';
          return true;
        }
      }

      node.classList.remove('zoro-stock--inline-price');
      document.getElementById('LowStockCounterSpacer-{{ block.id }}')?.remove();
      if (!document.body.contains(node)) document.body.appendChild(node);
      if (!positionProductPortal(node)) {
        node.hidden = true;
        return false;
      }
      root.dataset.productPlacement = 'portal';
      node.hidden = false;
      return true;
    };

    const retryProductPlacement = () => {
      if (pageType !== 'product') return;
      [40, 160, 420, 900, 1800, 3200, 5200, 8000].forEach((delay) => {
        window.setTimeout(() => {
          if (lastPortalRender) {
            renderProductPortal(
              lastPortalRender.copy,
              lastPortalRender.count,
              lastPortalRender.progressVisible,
              lastPortalRender.soldOut
            );
          }
        }, delay);
      });
    };

    const show = (copy, count = 0, progressVisible = false, soldOut = false) => {
      message.textContent = copy;
      if (soldOutBadge) soldOutBadge.hidden = !soldOut;
      progress.hidden = !showProgress || !progressVisible;
      progress.setAttribute('aria-valuenow', String(count));
      fill.style.width = `${Math.min(100, Math.max(0, count / threshold * 100))}%`;

      if (pageType === 'product') {
        root.dataset.cardMode = 'true';
        inventory.hidden = true;
        root.hidden = true;
        renderProductPortal(copy, count, progressVisible, soldOut);
        retryProductPlacement();
        return;
      }

      inventory.hidden = false;
      root.hidden = false;
    };

    const hide = () => {
      inventory.hidden = true;
      if (soldOutBadge) soldOutBadge.hidden = true;
      if (portal) portal.hidden = true;
      if (portalWatch) {
        window.clearInterval(portalWatch);
        portalWatch = null;
      }
      setRootVisibility();
    };

    window.addEventListener('resize', () => {
      if (lastPortalRender && portal && !portal.hidden) renderProductPortal(
        lastPortalRender.copy,
        lastPortalRender.count,
        lastPortalRender.progressVisible,
        lastPortalRender.soldOut
      );
    }, { passive: true });
    window.addEventListener('scroll', () => {
      if (lastPortalRender && portal && !portal.hidden) positionProductPortal(portal);
    }, { passive: true });

    const selectedVariantId = (event) => {
      const detail = event?.detail?.variant || event?.detail;
      if (detail?.id) return String(detail.id);

      const section = root.closest('.shopify-section') || root.closest('section') || document;
      const form = section.querySelector('form[action*="/cart/add"]')
        || document.querySelector('form[action*="/cart/add"]');
      const input = form?.querySelector('[name="id"]');
      return String(
        input?.value
        || new URLSearchParams(location.search).get('variant')
        || root.dataset.variantId
      );
    };

    const update = (event) => {
      if (pageType !== 'product') {
        hide();
        return;
      }

      if (!variants.length) {
        if (designMode && pageType === 'product') show(root.dataset.editorMessage || 'Place this block on a product template.');
        else hide();
        return;
      }

      const id = selectedVariantId(event);
      const variant = variants.find((item) => String(item.id) === id) || variants[0];
      if (!variant) return hide();

      if (!variant.available) {
        if (root.dataset.showSoldOut === 'true' || soldOutBadge) {
          show(
            root.dataset.showSoldOut === 'true' ? root.dataset.soldOutMessage : '',
            0,
            false,
            true
          );
        }
        else hide();
        return;
      }

      const quantity = Number(variant.quantity);
      const tracked = Boolean(variant.management)
        && variant.policy !== 'continue'
        && Number.isFinite(quantity);

      if (!tracked) {
        if (root.dataset.showUntracked === 'true') show(root.dataset.untrackedMessage);
        else hide();
        return;
      }

      if (displayMode === 'low_only' && quantity > threshold) return hide();
      const copy = root.dataset.countDisplay === 'exact'
        ? text(root.dataset.lowMessage, quantity)
        : root.dataset.generalMessage;
      show(copy, quantity, true);
    };

    const scheduleUpdate = (event) => {
      window.clearTimeout(updateTimer);
      updateTimer = window.setTimeout(() => update(event), 40);
    };

    ['variant:change', 'product:variant-change', 'variantChanged', 'shopify:variant:change']
      .forEach((name) => document.addEventListener(name, scheduleUpdate));

    document.addEventListener('change', (event) => {
      if (event.target.closest(
        'variant-selects, variant-radios, [data-variant-selector], form[action*="/cart/add"]'
      )) scheduleUpdate(event);
    });
    window.addEventListener('popstate', scheduleUpdate);
    document.addEventListener('shopify:section:load', scheduleUpdate);
    document.addEventListener('shopify:block:select', (event) => {
      if (event.target.contains(root) || event.target === root) update(event);
    });
    document.addEventListener('shopify:section:unload', (event) => {
      if (event.target.contains(root)) window.clearTimeout(updateTimer);
    });

    if (addBothButton && companionVariant) {
      addBothButton.addEventListener('click', async () => {
        const currentId = Number(selectedVariantId());
        const companionId = Number(companionVariant.value);
        if (!currentId || !companionId) return;

        addBothButton.disabled = true;
        addBothButton.textContent = root.dataset.addingText;
        pairStatus.textContent = '';

        try {
          const base = window.Shopify?.routes?.root || '/';
          const response = await fetch(`${base}cart/add.js`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              items: [
                { id: currentId, quantity: 1 },
                { id: companionId, quantity: 1 }
              ]
            })
          });
          if (!response.ok) throw new Error('Cart request failed');

          addBothButton.textContent = root.dataset.addedText;
          pairStatus.textContent = root.dataset.addedText;
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          document.dispatchEvent(new CustomEvent('cart:updated'));
          if (root.dataset.afterAdd === 'cart') {
            window.location.assign(`${base}cart`);
            return;
          }
        } catch (error) {
          pairStatus.textContent = root.dataset.addErrorText;
        }

        addBothButton.disabled = false;
        addBothButton.textContent = root.dataset.addBothText;
      });
    }

    update();
    setRootVisibility();
  })();
</script>

<script>
  (() => {
    const root = document.getElementById('LowStockCounter-{{ block.id }}');
    if (!root || root.dataset.adaptiveReady === 'true') return;
    root.dataset.adaptiveReady = 'true';

    const collectionSource = document.querySelector('[data-zoro-collection-products="{{ block.id }}"]');
    const cartSource = document.querySelector('[data-zoro-cart-items="{{ block.id }}"]');
    const threshold = Math.max(1, Number(root.dataset.threshold) || 10);
    const showSoldOut = root.dataset.showSoldOut === 'true';
    const displayMode = root.dataset.displayMode || 'always';
    const relatedDisplay = root.dataset.relatedDisplay || 'simple';
    const countDisplay = root.dataset.countDisplay || 'exact';
    const badgeClass = 'zoro-adaptive-stock-badge-{{ block.id }}';
    const adaptiveList = root.querySelector('[data-zoro-adaptive-list]');
    const inventory = root.querySelector('[data-zoro-inventory]');
    const pair = root.querySelector('[data-zoro-pair]');
    const variantSource = root.querySelector('[data-zoro-variants]');
    const productVariants = JSON.parse(variantSource?.textContent || '[]');
    const productCache = new Map();
    const simulatedCounts = new Map();
    let productPriceBadge;

    const copy = (template, count) => (template || '').split('[count]').join(String(count));
    const cssEscape = (value) => (
      window.CSS?.escape
        ? window.CSS.escape(String(value))
        : String(value).replace(/["\\]/g, '\\$&')
    );

    const badgeFor = (item) => {
      const quantity = Number(item.quantity);
      if ((!item.available || item.variantAvailable === false) && showSoldOut) {
        return { copy: root.dataset.soldOutMessage || 'Sold out', state: 'sold-out' };
      }
      if (item.tracked && Number.isFinite(quantity)) {
        if (displayMode === 'low_only' && quantity > threshold) return null;
        const message = countDisplay === 'exact'
          ? copy(root.dataset.lowMessage, quantity)
          : root.dataset.generalMessage;
        return { copy: message, state: 'low' };
      }
      if (root.dataset.showUntracked === 'true') {
        return { copy: root.dataset.untrackedMessage, state: 'low' };
      }
      return null;
    };

    const relatedBadgeFor = (item) => {
      if (relatedDisplay === 'off') return null;
      if (relatedDisplay === 'exact') return badgeFor(item);

      const quantity = Number(item.quantity);
      if ((!item.available || item.variantAvailable === false) && showSoldOut) {
        return { copy: root.dataset.soldOutMessage || 'Sold out', state: 'sold-out' };
      }
      if (item.tracked && Number.isFinite(quantity)) {
        if (quantity > threshold) return null;
        return { copy: root.dataset.generalMessage, state: 'low' };
      }
      if (root.dataset.showUntracked === 'true') {
        return { copy: root.dataset.untrackedMessage, state: 'low' };
      }
      return null;
    };

    const makeBadge = (key, badge, placement = '') => {
      const node = document.createElement('span');
      node.className = placement ? `${badgeClass} ${badgeClass}--${placement}` : badgeClass;
      node.dataset.zoroAdaptiveStock = key;
      node.dataset.state = badge.state;
      if (placement) node.dataset.placement = placement;
      node.textContent = badge.copy;
      return node;
    };

    const hideProductInline = () => {
      if (root.dataset.pageType !== 'product' || !inventory) return;
      root.dataset.cardMode = 'true';
      inventory.hidden = true;
      if (!pair) root.hidden = true;
    };

    const removeProductPriceBadge = () => {
      document.getElementById('LowStockAdaptiveSpacer-{{ block.id }}')?.remove();
      productPriceBadge?.remove();
      productPriceBadge = null;
    };

    const removeCurrentProductOverlay = () => {
      document
        .querySelectorAll(`[data-zoro-adaptive-stock*="{{ block.id }}-current-"]`)
        .forEach((node) => node.remove());
    };

    const clearInline = () => {
      if (!adaptiveList) return;
      adaptiveList.replaceChildren();
      adaptiveList.hidden = true;
    };

    const renderInline = (entries) => {
      if (!adaptiveList || !entries.length) {
        clearInline();
        return;
      }

      adaptiveList.replaceChildren(...entries.slice(0, 8).map((entry) => {
        const item = document.createElement('div');
        item.className = 'zoro-stock__adaptive-item';

        const title = document.createElement('span');
        title.className = 'zoro-stock__adaptive-title';
        title.textContent = entry.title || '';

        item.append(title, makeBadge(entry.key, entry.badge));
        return item;
      }));

      adaptiveList.hidden = false;
      root.hidden = false;
    };

    const closestProductCard = (node, title) => {
      const productTitle = (title || '').trim();
      let current = node;

      while (current && current !== document.body) {
        const isCandidate = current.matches?.([
          '.card-wrapper',
          '.grid__item',
          '[class*="product-card"]',
          '[class*="card-wrapper"]',
          '[class*="product-grid"] li',
          'li',
          'article',
          'product-card'
        ].join(', '));
        const hasContent = !productTitle
          || (current.textContent || '').includes(productTitle)
          || current.querySelector?.('.price, [class*="price"], .card__heading, h2, h3');

        if (isCandidate && hasContent && !current.contains(root)) return current;
        current = current.parentElement;
      }

      return null;
    };

    const productCardFor = (product) => {
      const handle = product.handle || '';
      const title = (product.title || '').trim();
      const anchors = [...document.querySelectorAll(`a[href*="/products/${cssEscape(handle)}"]`)];
      for (const anchor of anchors) {
        const pathname = new URL(anchor.href, location.origin).pathname;
        if (!pathname.includes(`/products/${handle}`)) continue;
        const card = closestProductCard(anchor, title);
        if (card) return card;
      }

      if (title) {
        const titleNodes = [...document.querySelectorAll([
          '.card__heading',
          '.card-information',
          '.full-unstyled-link',
          '[class*="title"]',
          '[class*="heading"]',
          'h2',
          'h3',
          'a'
        ].join(', '))];
        for (const node of titleNodes) {
          if ((node.textContent || '').trim().includes(title)) {
            const card = closestProductCard(node, title);
            if (card) return card;
          }
        }
      }

      return null;
    };

    const selectedVariantId = () => {
      const section = root.closest('.shopify-section') || root.closest('section') || document;
      const form = section.querySelector('form[action*="/cart/add"]')
        || document.querySelector('form[action*="/cart/add"]');
      return String(
        form?.querySelector('[name="id"]')?.value
        || new URLSearchParams(location.search).get('variant')
        || root.dataset.variantId
      );
    };

    const currentProductItem = () => {
      if (root.dataset.pageType !== 'product' || !productVariants.length) return null;
      const variant = productVariants.find((item) => String(item.id) === selectedVariantId())
        || productVariants[0];
      if (!variant) return null;

      const quantity = Number(variant.quantity);
      return {
        handle: root.dataset.currentHandle,
        title: '',
        available: variant.available,
        variantAvailable: variant.available,
        quantity,
        tracked: Boolean(variant.management)
          && variant.policy !== 'continue'
          && Number.isFinite(quantity)
      };
    };

    const visibleBox = (node) => {
      const box = node?.getBoundingClientRect?.();
      if (!box || box.width < 1 || box.height < 1) return null;
      const style = window.getComputedStyle(node);
      if (style.display === 'none' || style.visibility === 'hidden' || Number(style.opacity) === 0) {
        return null;
      }
      return box;
    };

    const purchaseCopy = (node) =>
      (node?.textContent || node?.value || node?.getAttribute?.('aria-label') || '')
        .replace(/\s+/g, ' ')
        .trim()
        .toLowerCase();

    const purchaseShell = (node) =>
      node.closest?.([
        'form[action*="/cart/add"]',
        'product-form',
        '.product-form',
        '[class*="product-form"]',
        '[class*="buy-buttons"]',
        '[class*="payment-button"]',
        '[class*="quantity"]'
      ].join(', ')) || node;

    const productPurchaseButtons = () => [...document.querySelectorAll([
        'button',
        'input[type="submit"]',
        'a',
        '[role="button"]',
        '[name="add"]',
        '[class*="button"]',
        '[class*="payment-button"]'
      ].join(', '))]
        .filter((button) => {
          const copy = purchaseCopy(button);
          return !root.contains(button) && visibleBox(button) && /add to cart|buy it now|sold out/.test(copy);
        })
        .sort((left, right) => {
          const leftCopy = purchaseCopy(left);
          const rightCopy = purchaseCopy(right);
          const leftPriority = /add to cart|sold out/.test(leftCopy) ? 0 : 1;
          const rightPriority = /add to cart|sold out/.test(rightCopy) ? 0 : 1;
          const leftBox = left.getBoundingClientRect();
          const rightBox = right.getBoundingClientRect();
          return (leftPriority - rightPriority) || (rightBox.left - leftBox.left) || (leftBox.top - rightBox.top);
        });

    const productPurchaseColumnBox = () => {
      const button = productPurchaseButtons()[0];
      const buttonBox = visibleBox(button);
      if (!buttonBox) return null;

      const shell = purchaseShell(button);
      const shellBox = visibleBox(shell);
      if (shellBox && shellBox.width <= window.innerWidth * 0.62) return shellBox;

      return buttonBox;
    };

    const productFormTarget = () => {
      const columnBox = productPurchaseColumnBox();
      const forms = [...document.querySelectorAll('form[action*="/cart/add"]')]
        .filter((form) => {
          const box = visibleBox(form);
          if (!box || root.contains(form)) return false;
          if (!columnBox) return true;
          const overlap = Math.min(box.right, columnBox.right) - Math.max(box.left, columnBox.left);
          return box.width <= window.innerWidth * 0.62 && overlap > columnBox.width * 0.5;
        })
        .map((form) => {
          const box = form.getBoundingClientRect();
          const copy = purchaseCopy(form);
          return {
            form,
            priority: /add to cart|buy it now|sold out/.test(copy) ? 0 : 1,
            left: box.left,
            top: box.top
          };
        })
        .sort((left, right) =>
          (left.priority - right.priority)
          || (right.left - left.left)
          || (left.top - right.top)
        );

      return forms[0]?.form || null;
    };

    const productInfoContainer = () => {
      const form = productFormTarget();
      const purchase = productPurchaseTarget()?.node;
      return form?.closest([
        'product-info',
        '.product__info-container',
        '.product__info-wrapper',
        '[class*="product__info"]',
        '[class*="product-info"]'
      ].join(', '))
        || purchase?.closest([
          'product-info',
          '.product__info-container',
          '.product__info-wrapper',
          '[class*="product__info"]',
          '[class*="product-info"]'
        ].join(', '))
        || null;
    };

    const productPurchaseTarget = () => {
      const form = productFormTarget();
      if (visibleBox(form)) return { node: form, mode: 'before' };

      const purchaseButton = productPurchaseButtons()[0];
      if (!purchaseButton) return null;

      const shell = purchaseShell(purchaseButton);
      const shellBox = visibleBox(shell);
      if (shellBox && shellBox.width <= window.innerWidth * 0.62) {
        return {
          node: shell,
          mode: 'before'
        };
      }

      return {
        node: purchaseButton,
        mode: 'before'
      };
    };

    const productVisiblePriceTarget = () => {
      const purchaseBox = productPurchaseColumnBox() || visibleBox(productPurchaseTarget()?.node);
      if (!purchaseBox) return null;

      const candidates = [...document.querySelectorAll([
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]',
        'span',
        'div',
        'p',
        'dd'
      ].join(', '))]
        .filter((node) => {
          if (node === root || root.contains(node) || node.contains(root)) return false;
          const copy = (node.textContent || '').replace(/\s+/g, ' ').trim();
          if (!/[$£€]|(?:^|\s)(?:USD|CAD|AUD|GBP|EUR)(?:\s|$)|\d+[.,]\d{2}/.test(copy)) return false;
          if (copy.length > 80) return false;
          const box = visibleBox(node);
          if (!box || box.bottom > purchaseBox.top + 24) return false;
          const overlap = Math.min(box.right, purchaseBox.right) - Math.max(box.left, purchaseBox.left);
          const center = (box.left + box.right) / 2;
          return overlap > Math.min(box.width, purchaseBox.width) * 0.25
            || (center >= purchaseBox.left && center <= purchaseBox.right);
        })
        .sort((left, right) => {
          const leftBox = left.getBoundingClientRect();
          const rightBox = right.getBoundingClientRect();
          return Math.abs(purchaseBox.top - leftBox.bottom) - Math.abs(purchaseBox.top - rightBox.bottom);
        });

      return candidates[0] || null;
    };

    const productPriceBlockTarget = (node) => {
      if (!node) return null;
      return node.closest?.([
        '.price',
        '[data-product-price]',
        '[id*="price" i]',
        '[class*="price" i]'
      ].join(', ')) || node.parentElement || node;
    };

    const productPagePriceTarget = () => {
      const visiblePrice = productVisiblePriceTarget();
      const visiblePriceBlock = productPriceBlockTarget(visiblePrice);
      if (visiblePriceBlock) return visiblePriceBlock;

      const container = productInfoContainer();
      const selectors = [
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]'
      ];

      for (const selector of selectors) {
        const node = container?.querySelector(selector);
        const block = productPriceBlockTarget(node);
        if (block && !block.contains(root)) return block;
      }

      return productPurchaseTarget()?.node || null;
    };

    const placeProductRootNearPrice = () => {
      if (root.dataset.pageType !== 'product') return false;
      const target = productPagePriceTarget();
      if (!target || target.contains(root)) return false;

      const purchase = productPurchaseTarget();
      if (purchase?.node === target || purchase?.node?.contains(target)) {
        if (purchase.node.previousElementSibling !== root) {
          purchase.node.insertAdjacentElement('beforebegin', root);
        }
        root.dataset.productPlacement = 'price';
        return isVisible(root) || !root.hidden;
      }

      const form = target.matches?.('form[action*="/cart/add"]')
        ? target
        : target.closest?.('form[action*="/cart/add"]');
      const anchor = target.closest([
        '.price',
        '[id*="price" i]',
        '[class*="price" i]',
        '[data-product-price]'
      ].join(', ')) || target;

      if (form && !form.contains(root)) {
        form.insertAdjacentElement('beforebegin', root);
      } else if (anchor.nextElementSibling !== root) {
        anchor.insertAdjacentElement('afterend', root);
      }

      root.dataset.productPlacement = 'price';
      return isVisible(root) || !root.hidden;
    };

    const productPriceAnchor = () => {
      const price = productPagePriceTarget();
      if (price) {
        const form = price.closest?.([
          'form[action*="/cart/add"]',
          'product-form',
          '.product-form',
          '[class*="product-form"]'
        ].join(', '));
        if (form && form !== price && !root.contains(form)) {
          return { node: form, mode: 'before' };
        }
        return { node: price, mode: 'after' };
      }

      const purchase = productPurchaseTarget();
      if (purchase?.node) return { node: purchase.node, mode: 'before' };

      return null;
    };

    const positionProductPriceBadge = () => {
      if (!productPriceBadge) return false;
      const anchor = productPriceAnchor();
      if (!anchor?.node) return false;

      const anchorBox = visibleBox(anchor.node);
      const columnBox = productPurchaseColumnBox() || anchorBox;
      if (!anchorBox || !columnBox) return false;

      productPriceBadge.hidden = false;
      const badgeBox = productPriceBadge.getBoundingClientRect();
      const gap = 8;
      const width = Math.max(160, Math.min(columnBox.width, window.innerWidth - 24));
      const left = Math.max(12, Math.min(columnBox.left + window.scrollX, window.scrollX + window.innerWidth - width - 12));
      const top = anchor.mode === 'before'
        ? Math.max(window.scrollY + 12, anchorBox.top + window.scrollY - badgeBox.height - gap)
        : anchorBox.bottom + window.scrollY + gap;

      productPriceBadge.style.setProperty('--zoro-product-badge-width', `${width}px`);
      productPriceBadge.style.left = `${left}px`;
      productPriceBadge.style.top = `${top}px`;
      return true;
    };

    const renderProductPriceBadge = (badge) => {
      const anchor = productPriceAnchor();
      if (!anchor?.node) {
        removeProductPriceBadge();
        return false;
      }

      if (!productPriceBadge) {
        productPriceBadge = makeBadge('{{ block.id }}-product-price', badge, 'product-price');
        document.body.appendChild(productPriceBadge);
      } else {
        productPriceBadge.dataset.state = badge.state;
        productPriceBadge.textContent = badge.copy;
      }

      if (!anchor.node.contains(productPriceBadge)) {
        productPriceBadge.classList.add('zoro-adaptive-stock-badge--product-price-inline');
        productPriceBadge.style.removeProperty('--zoro-product-badge-width');
        productPriceBadge.style.removeProperty('left');
        productPriceBadge.style.removeProperty('top');
        if (anchor.mode === 'before') {
          anchor.node.insertAdjacentElement('beforebegin', productPriceBadge);
        } else {
          anchor.node.insertAdjacentElement('afterend', productPriceBadge);
        }
        productPriceBadge.style.setProperty('margin-top', '1.25rem', 'important');
        productPriceBadge.style.setProperty('margin-bottom', '3rem', 'important');
        productPriceBadge.style.setProperty('position', 'relative', 'important');
        productPriceBadge.style.setProperty('z-index', '1', 'important');
        let spacer = document.getElementById('LowStockAdaptiveSpacer-{{ block.id }}');
        if (!spacer) {
          spacer = document.createElement('div');
          spacer.id = 'LowStockAdaptiveSpacer-{{ block.id }}';
          spacer.setAttribute('aria-hidden', 'true');
        }
        if (productPriceBadge.nextElementSibling !== spacer) {
          productPriceBadge.insertAdjacentElement('afterend', spacer);
        }
        spacer.style.setProperty('display', 'block', 'important');
        spacer.style.setProperty('height', '1.5rem', 'important');
        spacer.style.setProperty('min-height', '1.5rem', 'important');
        spacer.style.setProperty('clear', 'both', 'important');
        spacer.style.setProperty('pointer-events', 'none', 'important');
        const next = spacer.nextElementSibling;
        if (next) {
          next.style.setProperty('margin-top', '3.75rem', 'important');
          next.style.setProperty('padding-top', '1rem', 'important');
        }
        productPurchaseButtons().forEach((button) => {
          button.style.setProperty('margin-top', '2.5rem', 'important');
        });
        productPriceBadge.hidden = false;
        if (isVisible(productPriceBadge)) return true;
      }

      productPriceBadge.classList.remove('zoro-adaptive-stock-badge--product-price-inline');
      document.getElementById('LowStockAdaptiveSpacer-{{ block.id }}')?.remove();
      if (!document.body.contains(productPriceBadge)) document.body.appendChild(productPriceBadge);

      if (!positionProductPriceBadge()) {
        removeProductPriceBadge();
        return false;
      }

      return true;
    };

    const handleFromProductHref = (href) => {
      try {
        const url = new URL(href, location.origin);
        const match = url.pathname.match(/\/products\/([^/?#]+)/);
        return match ? decodeURIComponent(match[1]) : '';
      } catch (error) {
        return '';
      }
    };

    const relatedProductCards = () => {
      if (root.dataset.pageType !== 'product') return [];

      const currentHandle = root.dataset.currentHandle || '';
      const seen = new Map();
      const anchors = [...document.querySelectorAll('a[href*="/products/"]')];
      anchors.forEach((anchor) => {
        const handle = handleFromProductHref(anchor.href);
        if (!handle || handle === currentHandle || seen.has(handle)) return;

        const title = (anchor.textContent || '').trim();
        const card = closestProductCard(anchor, title);
        if (!card || !card.querySelector('img')) return;

        seen.set(handle, {
          handle,
          card,
          title: title
            || card.querySelector('.card__heading, [class*="title"], h2, h3')?.textContent?.trim()
            || handle
        });
      });

      return [...seen.values()].slice(0, 12);
    };

    const productDataForHandle = (handle) => {
      if (productCache.has(handle)) return productCache.get(handle);

      const base = window.Shopify?.routes?.root || '/';
      const request = fetch(`${base}products/${encodeURIComponent(handle)}.js`, {
        credentials: 'same-origin',
        headers: { 'Accept': 'application/json' }
      })
        .then((response) => {
          if (!response.ok) throw new Error('Product lookup failed');
          return response.json();
        })
        .then((product) => {
          const variants = Array.isArray(product.variants) ? product.variants : [];
          const variant = variants.find((item) => item.available) || variants[0] || {};
          const quantity = Number(variant.inventory_quantity);
          const tracked = Boolean(variant.inventory_management)
            && variant.inventory_policy !== 'continue'
            && Number.isFinite(quantity);

          return {
            handle,
            title: product.title || handle,
            available: product.available !== false,
            variantAvailable: variant.available !== false,
            quantity,
            tracked
          };
        })
        .catch(() => null);

      productCache.set(handle, request);
      return request;
    };

    const cartLineFor = (item) => {
      const selectors = [
        `[href*="variant=${cssEscape(String(item.variantId))}"]`,
        `[href="${cssEscape(item.url)}"]`,
        `[href*="${cssEscape((item.url || '').split('?')[0])}"]`
      ];
      for (const selector of selectors) {
        const anchor = document.querySelector(selector);
        const line = anchor?.closest('.cart-item, .cart__row, tr, li, article, [data-cart-item]');
        if (line && !line.contains(root)) return line;
      }
      return null;
    };

    const isVisible = (node) => Boolean(node?.isConnected && node.getClientRects().length);

    const simulatedCountFor = (handle) => {
      if (simulatedCounts.has(handle)) return simulatedCounts.get(handle);

      let hash = 0;
      for (const char of String(handle)) {
        hash = (hash * 31 + char.charCodeAt(0)) >>> 0;
      }

      const max = Math.max(4, threshold);
      const count = 3 + (hash % Math.max(1, max - 2));
      simulatedCounts.set(handle, count);
      return count;
    };

    const decrementSimulatedCounts = () => {
      if (relatedDisplay !== 'exact') return;
      let changed = false;
      simulatedCounts.forEach((count, handle) => {
        if (count > 3) {
          simulatedCounts.set(handle, count - 1);
          changed = true;
        }
      });
      if (changed) renderRelatedProducts();
    };

    const mediaTargetFor = (card) => {
      if (!card) return null;
      const media = card.querySelector([
        '.card__media',
        '.media',
        '[class*="media"]',
        '[class*="image-wrapper"]',
        '[class*="image"]'
      ].join(', '));
      const image = card.querySelector('img');
      const target = media
        || image?.closest('a, .card__inner, .media, [class*="media"], [class*="image"]')
        || image?.parentElement;

      if (!target || target.contains(root)) return null;
      if (getComputedStyle(target).position === 'static') target.style.position = 'relative';
      return target;
    };

    const placeOverlayBadge = (card, key, badge) => {
      const existing = card?.querySelector(`[data-zoro-adaptive-stock="${key}"]`);
      if (existing) {
        existing.dataset.state = badge.state;
        existing.textContent = badge.copy;
        return isVisible(existing);
      }
      const target = mediaTargetFor(card);
      if (!target) return false;
      const node = makeBadge(key, badge, 'overlay');
      target.append(node);
      return isVisible(node);
    };

    const placeBadge = (target, key, badge, selector) => {
      const existing = target?.querySelector(`[data-zoro-adaptive-stock="${key}"]`);
      if (existing) return isVisible(existing);
      if (!target) return false;
      const anchor = target.querySelector(selector);
      const node = makeBadge(key, badge);
      (anchor || target).insertAdjacentElement('afterend', node);
      return isVisible(node);
    };

    const renderCollection = () => {
      if (!collectionSource || root.dataset.pageType === 'product') return;
      const products = JSON.parse(collectionSource.textContent || '[]');
      const inlineEntries = [];
      let placed = 0;
      products.forEach((product) => {
        const badge = badgeFor(product);
        if (!badge) return;
        const key = '{{ block.id }}-collection-' + product.handle;
        inlineEntries.push({ key, title: product.title, badge });
        if (placeOverlayBadge(productCardFor(product), key, badge)) placed += 1;
      });

      if (inlineEntries.length && placed === 0) {
        renderInline(inlineEntries);
      } else if (!cartSource) {
        clearInline();
      }
    };

    const renderProductPageOverlay = () => {
      removeCurrentProductOverlay();
      removeProductPriceBadge();
      hideProductInline();
    };

    const renderRelatedProducts = async () => {
      if (cartSource || root.dataset.pageType !== 'product') return;

      const cards = relatedProductCards();
      if (!cards.length) {
        hideProductInline();
        return;
      }

      let placed = 0;
      await Promise.all(cards.map(async (entry) => {
        const item = await productDataForHandle(entry.handle);
        if (!item) return;

        const itemForBadge = item.tracked || item.available === false || relatedDisplay !== 'exact'
          ? item
          : { ...item, tracked: true, quantity: simulatedCountFor(entry.handle) };
        const badge = relatedBadgeFor(itemForBadge);
        if (!badge) return;

        if (placeOverlayBadge(
          entry.card,
          '{{ block.id }}-related-' + entry.handle,
          badge
        )) placed += 1;
      }));

      hideProductInline();
      if (placed > 0) clearInline();
    };

    const renderCart = () => {
      if (!cartSource) return;
      const items = JSON.parse(cartSource.textContent || '[]');
      const inlineEntries = [];
      let placed = 0;
      items.forEach((item) => {
        const badge = badgeFor(item);
        if (!badge) return;
        const key = '{{ block.id }}-cart-' + item.key;
        inlineEntries.push({ key, title: item.title, badge });
        if (placeBadge(
          cartLineFor(item),
          key,
          badge,
          '.cart-item__details, .cart-item__name, .cart__meta, td, h3, a'
        )) placed += 1;
      });

      if (inlineEntries.length && placed === 0) {
        renderInline(inlineEntries);
      } else if (!collectionSource) {
        clearInline();
      }
    };

    renderCollection();
    renderCart();
    renderProductPageOverlay();
    renderRelatedProducts();
    document.addEventListener('shopify:section:load', () => {
      removeCurrentProductOverlay();
      renderCollection();
      renderCart();
      renderProductPageOverlay();
      renderRelatedProducts();
    });
    document.addEventListener('cart:updated', renderCart);
    window.addEventListener('resize', () => window.requestAnimationFrame(positionProductPriceBadge));
    window.addEventListener('scroll', () => window.requestAnimationFrame(positionProductPriceBadge), { passive: true });
    ['variant:change', 'product:variant-change', 'variantChanged', 'shopify:variant:change']
      .forEach((name) => document.addEventListener(name, () => {
        window.setTimeout(() => {
          renderProductPageOverlay();
          renderRelatedProducts();
        }, 80);
      }));
    document.addEventListener('change', (event) => {
      if (event.target.closest(
        'variant-selects, variant-radios, [data-variant-selector], form[action*="/cart/add"]'
      )) {
        window.setTimeout(() => {
          renderProductPageOverlay();
          renderRelatedProducts();
        }, 80);
      }
    });
    window.setInterval(decrementSimulatedCounts, 7000);
  })();
</script>

